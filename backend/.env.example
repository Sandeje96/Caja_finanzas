# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your real values
# NEVER commit the .env file to git
# ─────────────────────────────────────────────────────────────────────────────

# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# For local development: postgresql://user:password@localhost:5432/dbname
# For Railway: automatically set by Railway PostgreSQL plugin
DATABASE_URL=postgresql://finanzas_user:finanzas_pass@localhost:5432/finanzas_ia

# ─── JWT (Dashboard Authentication — Sprint 6) ────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutes in seconds
JWT_REFRESH_TOKEN_EXPIRES=604800    # 7 days in seconds

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Get these from Meta for Developers dashboard
# https://developers.facebook.com/apps/
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v18.0

# ─── OpenAI (Sprint 3) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MAX_CONTEXT_MESSAGES=10

# ─── Supabase Storage (Sprint 4) ──────────────────────────────────────────────
# The bucket must be PRIVATE — access via signed URLs only
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here
SUPABASE_BUCKET_RECEIPTS=receipts

# ─── App Defaults ─────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires
DEFAULT_CURRENCY=ARS
RATE_LIMIT_PER_MINUTE=30
